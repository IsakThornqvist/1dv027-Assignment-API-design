							"    pm.response.to.have.status(200)\r",
							"})\r",
							"\r",
							"pm.test(\"Returns token\", () => {\r",
							"    const json = pm.response.json()\r",
							"    pm.expect(json.data.register.token).to.be.a(\"string\")\r",
							"})\r",
